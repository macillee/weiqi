# Supabase environment variables (optional)
# Copy this file to .env.local and fill in the values to enable cloud sync.
# Do NOT commit .env.local to version control.
#
# The app works fully in local anonymous mode without these variables.
# If both variables are set, the app enables Supabase cloud-sync mode
# (email login, child profiles, server-side progress).
#
# Docker Compose automatically reads .env.local (if present) via env_file.
# Alternatively, pass values via shell environment:
#   NEXT_PUBLIC_SUPABASE_URL=... NEXT_PUBLIC_SUPABASE_ANON_KEY=... docker compose up --build
# Or use --env-file explicitly:
#   docker compose --env-file .env.local up --build
#
# Both variables are public browser-exposed keys (NEXT_PUBLIC_ prefix).
# NEVER use or expose the Supabase service_role key in client-side code
# or Docker public environment.

# Supabase project URL (from Settings > API in Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (from Settings > API in Supabase dashboard)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
